# Meshgram systemd environment file example
# Copy to /opt/meshgram/.env and set real values.

# Required
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_GROUP_ID=-1001234567890

# Optional runtime settings
MESHGRAM_CONFIG_PATH=/opt/meshgram/config.yaml
LOG_LEVEL=INFO

# Optional Meshtastic connection mode override (serial or tcp)
MESH_MODE=serial

# Optional: skip full node DB download during startup
MESH_NO_NODES=false

# Serial mode settings (used when mode=serial)
MESH_DEVICE=/dev/ttyUSB0

# TCP mode settings (used when mode=tcp)
MESH_HOST=localhost
MESH_PORT=4403

# Optional plugin env vars (dm_http_command examples)
SOLAR_HOST=192.168.0.10
SOLAR_TOKEN=replace_me
SOLAR_API_KEY=replace_me
