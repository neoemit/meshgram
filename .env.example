# Required
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_GROUP_ID=-1001234567890

# Optional runtime settings
MESHGRAM_CONFIG_PATH=config.yaml
LOG_LEVEL=INFO

# Mesh backend selector. Either "meshtastic" (default) or "meshcore".
MESH_BACKEND=meshtastic

# Connection mode override.
#   meshtastic backend: serial | tcp
#   meshcore backend:   serial | tcp | ble
MESH_MODE=serial

# Optional Meshtastic optimization: skip full node DB download on startup.
# Useful for unstable/proxied links (for example macOS serial->TCP bridge).
# Ignored when MESH_BACKEND=meshcore.
MESH_NO_NODES=false

# Serial device path. Used when mode=serial for either backend.
MESH_DEVICE=/dev/ttyUSB0

# Serial baud rate. Only honoured by MeshCore; Meshtastic auto-negotiates.
# MESH_BAUDRATE=115200

# TCP overrides (used when mode=tcp).
# Defaults: Meshtastic → port 4403, MeshCore → port 5000.
# For Docker Desktop on macOS, use host.docker.internal when bridging serial->TCP from host.
MESH_HOST=host.docker.internal
MESH_PORT=4403

# MeshCore BLE (used when MESH_BACKEND=meshcore and MESH_MODE=ble).
# MESH_BLE_ADDRESS=12:34:56:78:90:AB
# MESH_BLE_PIN=123456

# Optional plugin env vars (dm_http_command examples)
SOLAR_HOST=192.168.0.10
SOLAR_TOKEN=replace_me
SOLAR_API_KEY=replace_me
