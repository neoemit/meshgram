# Required
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_GROUP_ID=-1001234567890

# Optional runtime settings
MESHGRAM_CONFIG_PATH=config.yaml
LOG_LEVEL=INFO

# Optional Meshtastic connection mode override (serial or tcp)
MESH_MODE=serial

# Optional Meshtastic optimization: skip full node DB download on startup.
# Useful for unstable/proxied links (for example macOS serial->TCP bridge).
MESH_NO_NODES=false

# Optional Meshtastic serial override (mainly for Linux serial passthrough)
# Used when mode=serial
MESH_DEVICE=/dev/ttyUSB0

# Optional Meshtastic TCP overrides (used when mode=tcp)
# For Docker Desktop on macOS, use host.docker.internal when bridging serial->TCP from host.
MESH_HOST=host.docker.internal
MESH_PORT=4403

# Optional plugin env vars (dm_http_command examples)
SOLAR_HOST=192.168.0.10
SOLAR_TOKEN=replace_me
SOLAR_API_KEY=replace_me
